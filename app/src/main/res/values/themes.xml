<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. The real Material 3 colors live in
         Compose's PlateScannerTheme; this XML theme just gives the
         platform-level AppCompat baseline + edge-to-edge flags. -->
    <style name="Theme.PlateScanner" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_dark</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/primary_dark</item>
    </style>
</resources>
